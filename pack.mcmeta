package com.playeresp.mod;

import com.playeresp.mod.client.ESPOverlay;
import com.playeresp.mod.config.ESPConfig;
import com.playeresp.mod.events.PlayerTrackingEvents;
import com.playeresp.mod.keybind.KeyBindings;
import net.neoforged.api.distmarker.Dist;
import net.neoforged.bus.api.IEventBus;
import net.neoforged.fml.ModContainer;
import net.neoforged.fml.common.Mod;
import net.neoforged.fml.event.lifecycle.FMLClientSetupEvent;
import net.neoforged.neoforge.client.event.RegisterKeyMappingsEvent;
import net.neoforged.neoforge.common.NeoForge;

@Mod(value = PlayerESPMod.MOD_ID, dist = Dist.CLIENT)
public class PlayerESPMod {

    public static final String MOD_ID = "playeresp";

    public PlayerESPMod(IEventBus modBus, ModContainer container) {
        // Mod-bus listeners
        modBus.addListener(this::onClientSetup);
        modBus.addListener(KeyBindings::onRegisterKeyMappings);

        // Game-bus listeners (client only, @Dist.CLIENT guaranteed by annotation)
        NeoForge.EVENT_BUS.register(PlayerTrackingEvents.class);
        NeoForge.EVENT_BUS.register(ESPOverlay.class);

        ESPConfig.load();
    }

    private void onClientSetup(FMLClientSetupEvent event) {
        event.enqueueWork(KeyBindings::register);
    }
}
